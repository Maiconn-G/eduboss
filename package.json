{
  "name": "eduboss-arena-do-conhecimento",
  "version": "0.1.0",
  "description": "Protótipo educacional em Phaser 3 do jogo EduBoss: Arena do Conhecimento.",
  "author": "OpenAI Codex",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:web": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "desktop": "npm run build:web && electron .",
    "dist:win": "npm run build:web && electron-builder --win nsis"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.eduboss.arena",
    "productName": "EduBoss Arena do Conhecimento",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "EduBoss-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
